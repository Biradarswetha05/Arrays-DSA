class Solution:
    def jump(self, nums: List[int]) -> int:
        currend=0
        farthest=0
        jumps=0
        n=len(nums)
        for i in range(n-1):
            farthest=max(farthest,i+nums[i])
            if i==currend:
                jumps+=1
                currend=farthest
        return jumps



        
